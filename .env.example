OLLAMA_MODEL=llama3.1
OLLAMA_BASE_URL=http://localhost:11434

# Set to 0 to disable LLM-judged supervision/routing/eval-scoring (heuristics only)
MY_CREW_LLM_SUPERVISOR=1
MY_CREW_LLM_ROUTING=1
MY_CREW_LLM_SCORING=1

# Persistent memory tool database path
MY_CREW_MEMORY_DB=my_crew_memory.db

# FastAPI service (my-crew-api)
MY_CREW_API_HOST=127.0.0.1
MY_CREW_API_PORT=8000

MY_CREW_LOG_LEVEL=INFO
